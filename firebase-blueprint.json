{
  "entities": {
    "Neighborhood": {
      "title": "Neighborhood",
      "description": "User generated neighborhood boundaries",
      "type": "object",
      "properties": {
        "neighborhoodName": { "type": "string" },
        "homeLocation": { "type": "array" },
        "polygonPoints": { "type": "array" },
        "changesText": { "type": "string" },
        "otherNamesText": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["neighborhoodName", "homeLocation", "polygonPoints", "changesText", "otherNamesText", "createdAt"]
    }
  },
  "firestore": {
    "neighborhoods": {
      "schema": { "$ref": "#/entities/Neighborhood" },
      "description": "Stores user submitted neighborhoods"
    }
  }
}
